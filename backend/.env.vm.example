# AWS EC2 production environment template
# Copy to backend/.env on the VM and fill real values.

NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_LIMIT=8
REFRESH_TTL_MS=60000

# CORS
FRONTEND_URL=https://your-domain.com

# Runtime service endpoints (inside docker network)
REDIS_HOST=redis
REDIS_PORT=6379

# Database (AWS-first baseline: self-hosted Postgres in docker-compose.prod)
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=collab_user
DB_PASSWORD=collab_pass
DB_NAME=collab_workspace
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Optional Oracle fields (keep empty when DB_TYPE=postgres)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=

# Storage (AWS-first baseline: MinIO in docker-compose.prod)
STORAGE_TYPE=minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=collab-workspace

# Optional notes:
# - For SSL automation scripts, set DOMAIN/CERTBOT_EMAIL at deploy runtime.
# - If you later migrate to RDS/S3, switch DB/STORAGE settings accordingly.

# Google Integrations (optional, required only when enabling P3 features)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/calendar
GOOGLE_SYNC_MAX_ATTEMPTS=5
GOOGLE_SYNC_RETRY_BASE_MS=300000
