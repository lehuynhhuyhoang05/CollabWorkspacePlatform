# Production VM environment template
# Copy to backend/.env on the VM and fill real values.

NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_LIMIT=8
REFRESH_TTL_MS=60000

# CORS
FRONTEND_URL=https://your-domain.com

# Runtime service endpoints (inside docker network)
REDIS_HOST=redis
REDIS_PORT=6379

# Database mode (phase 2 uses Oracle)
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=5432
DB_USER=ignored_when_oracle
DB_PASSWORD=ignored_when_oracle
DB_NAME=ignored_when_oracle
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Oracle Autonomous DB
ORACLE_USER=app_user
ORACLE_PASSWORD=change_me
ORACLE_CONNECTION_STRING=adb.<region>.oraclecloud.com:1522/<service_name>

# Storage mode (phase 2 can switch to OCI)
STORAGE_TYPE=oci
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=unused_when_oci
MINIO_SECRET_KEY=unused_when_oci
MINIO_BUCKET_NAME=collab-workspace

# Optional notes:
# - If still running local phase on VM, set DB_TYPE=postgres and STORAGE_TYPE=minio.
# - For SSL automation scripts, set DOMAIN/CERTBOT_EMAIL at deploy runtime.
